{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Live Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", ".", "--port=3000", "--no-browser"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    }
  ]
}
